#!/usr/bin/env bash
# exakit — lifecycle helper for the Exasol Personal Local Starter Kit.
#
# usage: exakit <command>
#
#   preflight           check this machine's requirements, install nothing
#   status              show what is installed and whether it is healthy
#   version             kit source, install date, component versions
#   info                print the connection details panel
#   start               start the local database
#   stop                stop the local database
#   load-data [--force] load the sample dataset (schema + CSVs + verify)
#   data-load           open guided data loading options
#   mcp-configs         regenerate the ready-made temporary MCP config bundle
#   mcp-setup           choose temporary or permanent MCP client setup
#   mcp-status          show managed MCP state
#   mcp-validate        validate managed MCP configs and connectivity
#   mcp-repair          repair managed MCP config drift
#   mcp-doctor          run MCP diagnostics
#   mcp-remove          remove managed MCP config from the supported clients
#   mcp-restore         restore the latest (or a chosen) MCP snapshot
#   skills-install      install the kit's AI skills for CLI agents
#                       (~/.claude/skills, ~/.agents/skills)
#   teardown [--data]   remove the runtime; --data also deletes database
#                       content (Nano volume / Personal deployment)
#   logs                print the path of the latest setup log
#   catalog [search]    browse/search every exakit, exapump & exasol command
#   help                this text
#
# Installed to ~/.local/bin by the setup scripts; also runs straight from a
# repo checkout (setup/exakit).

set -u
set -o pipefail

# --- locate the kit's lib directory ----------------------------------------
_script_dir="$(cd "$(dirname "$0")" && pwd)"
if [ -f "$_script_dir/lib/common.sh" ]; then
    _lib_dir="$_script_dir/lib"
elif [ -f "${EXAKIT_HOME:-$HOME/.exasol-starter-kit}/kit/setup/lib/common.sh" ]; then
    _lib_dir="${EXAKIT_HOME:-$HOME/.exasol-starter-kit}/kit/setup/lib"
else
    echo "exakit: cannot find the kit library (looked in $_script_dir/lib and ~/.exasol-starter-kit/kit)" >&2
    exit 1
fi

. "$_lib_dir/common.sh"
. "$_lib_dir/detect.sh"
. "$_lib_dir/runtime-nano.sh"
. "$_lib_dir/runtime-personal.sh"
[ -f "$_lib_dir/exapump.sh" ] && . "$_lib_dir/exapump.sh"

_runtime_type() {
    manifest_get runtime.type 2>/dev/null
}

_require_install() {
    [ -f "$EXAKIT_MANIFEST" ] || die "No installation found. Run the installer first."
    [ -n "$(_runtime_type)" ] || die "No runtime recorded in the manifest yet."
}

cmd_status() {
    if [ ! -f "$EXAKIT_MANIFEST" ]; then
        echo "Not installed (no manifest at $EXAKIT_MANIFEST)"
        exit 0
    fi
    _type="$(_runtime_type)"
    printf 'Kit level:  %s\n' "$(manifest_get kit_level 2>/dev/null)"
    printf 'Runtime:    %s\n' "${_type:-none}"
    case "$_type" in
        nano)     printf 'Status:     %s\n' "$(nano_status)" ;;
        personal) printf 'Status:     %s\n' "$(personal_status)" ;;
        *)        printf 'Status:     unknown\n' ;;
    esac
    printf 'Steps done: %s\n' "$(manifest_get steps_completed 2>/dev/null)"
    printf 'Manifest:   %s\n' "$EXAKIT_MANIFEST"
}

cmd_start() {
    _require_install
    case "$(_runtime_type)" in
        nano)     nano_start ;;
        personal) personal_start ;;
    esac
}

cmd_stop() {
    _require_install
    case "$(_runtime_type)" in
        nano)     nano_stop ;;
        personal) personal_stop ;;
    esac
}

cmd_teardown() {
    _require_install
    _type="$(_runtime_type)"
    warn "This removes the local Exasol runtime ($_type)."
    if [ "${1:-}" = "--data" ]; then
        warn "It will ALSO delete all database content."
    fi
    confirm "Continue with teardown?" n || { info "Teardown cancelled"; exit 0; }
    case "$_type" in
        nano)     nano_teardown "${1:-}" || exit 1 ;;
        personal) personal_teardown "${1:-}" || exit 1 ;;
    esac
    ok "Teardown finished. Credentials, logs and the manifest remain in $EXAKIT_HOME"
    info "Remove them with: rm -rf $EXAKIT_HOME"
}

cmd_version() {
    [ -f "$EXAKIT_MANIFEST" ] || { echo "Not installed (no manifest at $EXAKIT_MANIFEST)"; exit 0; }
    printf 'Kit level:      %s\n' "$(manifest_get kit_level 2>/dev/null)"
    printf 'Kit source:     %s\n' "$(manifest_get kit.source 2>/dev/null)"
    printf 'Installed at:   %s\n' "$(manifest_get installed_at 2>/dev/null)"
    printf 'Runtime:        %s %s\n' "$(manifest_get runtime.type 2>/dev/null)" \
        "$(manifest_get runtime.version 2>/dev/null || manifest_get runtime.image 2>/dev/null)"
    printf 'exapump:        %s\n' "$(manifest_get components.exapump.version 2>/dev/null)"
    printf 'MCP server:     %s %s\n' "$(manifest_get components.mcp_server.package 2>/dev/null)" \
        "$(manifest_get components.mcp_server.version 2>/dev/null)"
}

cmd_logs() {
    _latest="$(ls -t "$EXAKIT_LOG_DIR"/*.log 2>/dev/null | head -1)"
    if [ -n "$_latest" ]; then
        echo "$_latest"
    else
        echo "No logs found in $EXAKIT_LOG_DIR" >&2
        exit 1
    fi
}

cmd_load_data() {
    _require_install
    case "${1:-}" in
        ""|--force) ;;
        *) die "Unknown option '$1' for load-data (only --force is supported)." ;;
    esac
    command -v exakit_load_sample_data >/dev/null 2>&1 || \
        die "The exapump data-loading module is not available in this kit build."
    exakit_init_logging
    _kit_root="$(exakit_repo_root)" || \
        die "Could not find the kit's sql/ and data/ files to load."
    info "Loading the sample dataset (log: ${EXAKIT_LOG_FILE:-none})"
    exakit_load_sample_data "$_kit_root" "${1:-}"
}

cmd_data_load_menu() {
    _require_install
    command -v exakit_data_load_menu >/dev/null 2>&1 || \
        die "The exapump data-loading module is not available in this kit build."
    exakit_init_logging
    exakit_data_load_menu
}

cmd_mcp_configs() {
    _require_install
    exakit_init_logging
    exakit_generate_mcp_configs || die "Could not generate MCP client configs"
}

cmd_mcp_setup() {
    _require_install
    exakit_init_logging
    exakit_mcp_setup || die "Could not complete MCP client setup"
}

cmd_mcp_status() {
    _require_install
    exakit_init_logging
    exakit_mcp_operation status "$@" || die "Could not inspect MCP state"
}

cmd_mcp_validate() {
    _require_install
    exakit_init_logging
    exakit_mcp_operation validate "$@" || die "Could not validate MCP state"
}

cmd_mcp_repair() {
    _require_install
    exakit_init_logging
    exakit_mcp_operation repair "$@" || die "Could not repair MCP state"
}

cmd_mcp_doctor() {
    _require_install
    exakit_init_logging
    exakit_mcp_operation doctor "$@" || die "Could not run MCP diagnostics"
}

cmd_mcp_remove() {
    _require_install
    exakit_init_logging
    exakit_mcp_operation uninstall "$@" || die "Could not remove managed MCP configuration"
}

cmd_mcp_restore() {
    _require_install
    exakit_init_logging
    exakit_mcp_restore "${1:-}" || die "Could not restore managed MCP configuration"
}

cmd_skills_install() {
    exakit_init_logging
    exakit_install_skills || die "Could not install the kit's AI skills"
}

usage() {
    sed -n '2,26p' "$0" | sed 's/^# \{0,1\}//'
}

# cmd_catalog [search] — render the searchable command catalog from the shared
# catalog.tsv (one source of truth for both the bash and PowerShell CLIs).
cmd_catalog() {
    _search="$(printf '%s' "${1:-}" | tr '[:upper:]' '[:lower:]')"
    _catalog="$_lib_dir/catalog.tsv"
    [ -f "$_catalog" ] || die "Catalog data not found: $_catalog"

    if [ -t 1 ]; then
        _cy=$'\033[36m'; _cyb=$'\033[1;36m'; _dim=$'\033[2m'; _b=$'\033[1m'; _gn=$'\033[1;32m'; _r=$'\033[0m'
    else
        _cy=; _cyb=; _dim=; _b=; _gn=; _r=
    fi
    _rule='━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━'

    printf '\n  %s%s%s\n' "$_cy" "$_rule" "$_r"
    printf '   %s▸ EXASOL%s  %s·%s  starter kit\n' "$_cyb" "$_r" "$_dim" "$_r"
    if [ -n "$_search" ]; then
        printf '     %scommand catalog — results for "%s"%s\n' "$_dim" "$_search" "$_r"
    else
        printf '     %scommand catalog · exakit · exapump · exasol%s\n' "$_dim" "$_r"
    fi
    printf '  %s%s%s\n\n' "$_cy" "$_rule" "$_r"

    _found=0
    for _tool in exakit exapump exasol; do
        # Emit fields separated by US (0x1f), a non-whitespace char: `read` with
        # a tab IFS collapses the empty options field (tab is IFS-whitespace),
        # which would merge no-option commands onto their description line.
        _rows="$(awk -F'\t' -v tool="$_tool" -v q="$_search" '
            NR==1 {next}
            $1==tool {
                hay=tolower($1" "$2" "$3" "$4)
                if (q=="" || index(hay,q)>0) print $2"\037"$3"\037"$4
            }' "$_catalog")"
        [ -z "$_rows" ] && continue
        _found=1
        case "$_tool" in
            exakit)  _label='exakit   — kit lifecycle & MCP management' ;;
            exapump) _label='exapump  — data loading CLI' ;;
            exasol)  _label='exasol   — database & AI (MCP) bridge' ;;
        esac
        printf '  %s%s%s\n' "$_gn" "$_label" "$_r"
        printf '%s\n' "$_rows" | while IFS=$(printf '\037') read -r _cmd _opt _desc; do
            if [ "$_tool" = "exasol" ]; then _name="$_cmd"; else _name="$_tool $_cmd"; fi
            if [ -n "$_opt" ]; then
                printf '    %s%s%s %s%s%s\n' "$_b" "$_name" "$_r" "$_dim" "$_opt" "$_r"
            else
                printf '    %s%s%s\n' "$_b" "$_name" "$_r"
            fi
            printf '        %s\n' "$_desc"
        done
        printf '\n'
    done

    if [ "$_found" -eq 0 ]; then
        printf '  %sNo commands match "%s".%s  Try: exakit catalog mcp\n\n' "$_dim" "$_search" "$_r"
        return 0
    fi
    printf '  %sTip:%s exakit catalog <search>   e.g. exakit catalog data · exakit catalog mcp\n\n' "$_dim" "$_r"
}

case "${1:-help}" in
    preflight) preflight_report ;;
    status)   cmd_status ;;
    version)  cmd_version ;;
    info)     connection_panel ;;
    start)    cmd_start ;;
    stop)     cmd_stop ;;
    load-data) shift; cmd_load_data "${1:-}" ;;
    data-load) cmd_data_load_menu ;;
    mcp-configs) cmd_mcp_configs ;;
    mcp-setup) cmd_mcp_setup ;;
    mcp-status) shift; cmd_mcp_status "$@" ;;
    mcp-validate) shift; cmd_mcp_validate "$@" ;;
    mcp-repair) shift; cmd_mcp_repair "$@" ;;
    mcp-doctor) shift; cmd_mcp_doctor "$@" ;;
    mcp-remove) shift; cmd_mcp_remove "$@" ;;
    mcp-restore) shift; cmd_mcp_restore "$@" ;;
    skills-install) cmd_skills_install ;;
    teardown) shift; cmd_teardown "${1:-}" ;;
    logs)     cmd_logs ;;
    catalog)  shift; cmd_catalog "${1:-}" ;;
    help|-h|--help) usage ;;
    *) echo "exakit: unknown command '${1}'" >&2; usage >&2; exit 2 ;;
esac
